# ============================================
# Supabase Edge Functions — Environment Variables
# ============================================
# Copy this to your Supabase project:
#   supabase secrets set --env-file .env
# ============================================

# SMTP: Alibaba Cloud Enterprise Email (阿里云企业邮箱)
# 注意：SMTP_PASS 不是网页登录密码，而是阿里云企业邮箱的“客户端授权码”
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_USER=sales@dingqilighting.com
SMTP_PASS=your-smtp-client-auth-code
